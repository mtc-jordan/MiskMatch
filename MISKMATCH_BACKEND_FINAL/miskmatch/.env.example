# ─────────────────────────────────────────────
# MiskMatch — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# App
APP_NAME=MiskMatch
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development  # development | staging | production
SECRET_KEY=your-super-secret-key-minimum-32-chars-change-this
ALLOWED_HOSTS=["localhost","127.0.0.1"]
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Database — PostgreSQL (Supabase)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/miskmatch
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/miskmatch
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# Cache — Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# Auth — JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# Storage — AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=me-south-1  # Bahrain region for MENA latency
S3_BUCKET_PROFILES=miskmatch-profiles
S3_BUCKET_MEDIA=miskmatch-media
CLOUDFRONT_URL=https://cdn.miskmatch.app

# Communications — Twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE=+1234567890

# Email — SendGrid
SENDGRID_API_KEY=your-sendgrid-key
FROM_EMAIL=noreply@miskmatch.app
FROM_NAME=MiskMatch

# Biometric — Onfido
ONFIDO_API_KEY=your-onfido-key
ONFIDO_WEBHOOK_SECRET=your-onfido-webhook-secret

# Video Calls — Agora
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERT=your-agora-cert

# Payments — Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_NOOR_MONTHLY=price_xxx
STRIPE_PRICE_MISK_MONTHLY=price_xxx

# AI — OpenAI (for chat moderation + compatibility)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Sentry (error tracking)
SENTRY_DSN=https://xxx@sentry.io/xxx

# Admin
ADMIN_EMAIL=admin@miskmatch.app
ADMIN_PASSWORD=change-this-immediately
