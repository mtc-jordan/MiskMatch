# ─────────────────────────────────────────────
# MiskMatch — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# App
APP_NAME=MiskMatch
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development  # development | staging | production
SECRET_KEY=CHANGE_ME_minimum_32_characters_long
ALLOWED_HOSTS=["localhost","127.0.0.1"]
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]
PRODUCTION_ORIGINS=https://miskmatch.app,https://www.miskmatch.app,https://admin.miskmatch.app

# Database — PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/miskmatch
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/miskmatch
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Cache — Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=30
CACHE_TTL=300

# Auth — JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# Storage — AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-south-1
S3_BUCKET_PROFILES=miskmatch-profiles
S3_BUCKET_MEDIA=miskmatch-media
CLOUDFRONT_URL=

# Firebase — Push Notifications
FIREBASE_CREDENTIALS_PATH=

# Communications — Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# Email — SendGrid
SENDGRID_API_KEY=
FROM_EMAIL=noreply@miskmatch.app
FROM_NAME=MiskMatch

# Biometric — Onfido
ONFIDO_API_KEY=
ONFIDO_WEBHOOK_SECRET=

# Video Calls — Agora
AGORA_APP_ID=
AGORA_APP_CERT=

# Payments — Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_NOOR_MONTHLY=
STRIPE_PRICE_MISK_MONTHLY=

# AI — OpenAI (for chat moderation + compatibility)
OPENAI_API_KEY=

# Sentry (error tracking)
SENTRY_DSN=

# Admin
ADMIN_EMAIL=admin@miskmatch.app
ADMIN_PASSWORD=CHANGE_ME_for_production
